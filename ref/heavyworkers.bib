
@article{fang_does_2024,
	title = {Does automation really reduce jobs?},
	volume = {4},
	issn = {26671115},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S2667111524000239},
	doi = {10.1016/j.aglobe.2024.100099},
	abstract = {Using panel data from 63 countries in 2005–2021 and the generalised method of moments, this paper examines the impact of industrial robot utilisation on employment. Results show a 1 \% increase in new industrial robot installations per 10,000 workers reduces the unemployment rate by 0.037 \%-0.039 \%. The impact is more pronounced for male workers (0.045 \%) than female workers (0.033 \%), and youth unemployment is more significantly affected. Lastly, automation is found to reduce the unemployment rate by 0.052 \% for people with intermediate education, yet with little effect on those with basic or advanced educational attainment.},
	pages = {100099},
	number = {2},
	journaltitle = {Asia and the Global Economy},
	shortjournal = {Asia and the Global Economy},
	author = {Fang, Zheng and Kang, Soon Hock and May, Sandra Myo Han},
	urldate = {2026-04-27},
	date = {2024-07},
	langid = {english},
	file = {PDF:/home/gongbaodd/Zotero/storage/HG45869X/Fang et al. - 2024 - Does automation really reduce jobs.pdf:application/pdf},
}

