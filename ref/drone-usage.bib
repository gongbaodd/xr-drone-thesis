	langid = {english},
	file = {Full Text:/home/gongbaodd/Zotero/storage/AIMSQ6Z8/Otto et al. - 2018 - Optimization approaches for civil applications of unmanned aerial vehicles (UAVs) or aerial drones.pdf:application/pdf},
}
