
@article{turk_assumptions_2005,
	title = {Assumptions Underlying Agile Software-Development Processes:},
	volume = {16},
	issn = {1063-8016, 1533-8010},
	url = {https://services.igi-global.com/resolvedoi/resolve.aspx?doi=10.4018/jdm.2005100104},
	doi = {10.4018/jdm.2005100104},
	shorttitle = {Assumptions Underlying Agile Software-Development Processes},
	abstract = {Agile processes focus on facilitating early and fast production of working code, and are based on software development process models that support iterative, incremental development of software. Although agile methods have existed for a number of years now, answers to questions concerning the suitability of agile processes to particular software development environments are still often based on anecdotal accounts of experiences. An appreciation of the (often unstated) assumptions underlying agile processes can lead to a better understanding of the applicability of agile processes to particular situations. Agile processes are less likely to be applicable in situations in which core assumptions do not hold. This paper examines the principles and advocated practices of agile processes to identify underlying assumptions. The paper also identifies limitations that may arise from these assumptions and outlines how the limitations can be addresses by incorporating other software development techniques and practices into agile development environments.},
	pages = {62--87},
	number = {4},
	journaltitle = {Journal of Database Management},
	author = {Turk, Daniel and {France. Robert} and Rumpe, Bernhard},
	urldate = {2026-04-28},
	date = {2005-10-01},
	langid = {english},
	file = {PDF:/home/gongbaodd/Zotero/storage/9CFN4IGD/Turk et al. - 2005 - Assumptions Underlying Agile Software-Development Processes.pdf:application/pdf},
}

